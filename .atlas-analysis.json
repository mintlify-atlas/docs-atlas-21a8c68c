  "keyFeatures": [
    "Real-time seat locking with Socket.IO and Redis",
    "QR-code based digital tickets with offline access",
    "Multiple event types: seating, open-zone, online, and registration-based",
    "Google OAuth and OTP-based authentication",
    "Organizer dashboard with analytics and payout management",
    "Razorpay payment integration with refund support",
    "BullMQ background job queues for async operations",
    "Mobile-first responsive design with React and TailwindCSS",
    "Combo tickets, coupons, and referral discounts",
    "In-event chatrooms and attendee communication",
    "Admin portal for event approval and issue management"
  ],
